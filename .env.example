# Supabase — skopiuj do .env.local i uzupełnij klucze z dashboardu (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# Seed / legacy MVP customer (Piotr) — skrypty + linkowanie OWNER_EMAIL
SEED_CUSTOMER_ID=a0000000-0000-4000-8000-000000000001

# Demo customer (opcjonalnie; domyślnie b0000000-…)
# DEMO_CUSTOMER_ID=b0000000-0000-4000-8000-000000000001

# Po Google login: e-mail właściciela → podpięcie do SEED_CUSTOMER_ID (51 meczów)
OWNER_EMAIL=twoj@gmail.com

# Public URL (SEO canonical). Dev: localhost. Prod: https://…
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Auth setup (Supabase Dashboard) — v1.1.0 ---
# 1. Google Cloud OAuth → redirect: https://<ref>.supabase.co/auth/v1/callback
# 2. Authentication → Providers → Google (Client ID/Secret)
# 3. Authentication → URL Configuration:
#    Site URL (Mac):     http://localhost:3000
#    Site URL (iPhone):  http://<IP-Maca>:3000   ← inaczej Safari ląduje na localhost telefonu
#    Redirect URLs:
#      http://localhost:3000/auth/callback
#      http://<IP-Maca>:3000/auth/callback
#      https://twoja-domena/auth/callback
# 4. App flow: /login → /api/auth/google → Google → /auth/callback → /profile|/onboarding
#
# Test user BEZ Google (dev) — e-mail + hasło:
#   1. Supabase → Authentication → Providers → Email = ON
#   2. npm run auth:test-user -- test@example.com --name "Anna Nowak"
#   3. /login → wpisz wypisane e-mail i hasło
#   (stary magic link nie jest potrzebny)
