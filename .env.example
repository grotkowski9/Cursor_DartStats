# Supabase — skopiuj do .env.local i uzupełnij wartości z dashboardu (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# MVP: stały customer_id (seed w migracji)
DEFAULT_CUSTOMER_ID=a0000000-0000-4000-8000-000000000001
